// Prisma Schema — Paróquia São Sebastião
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ─────────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN  // Acesso irrestrito ao sistema
  ADMIN        // Administrador paroquial
  FINANCE      // Financeiro — dízimos e relatórios
  SECRETARY    // Secretaria — sacramentos e eventos
  COORDINATOR  // Coordenadores de movimentos/pastorais
  DIZIMISTA    // Área exclusiva do dizimista
  EDITOR       // Deprecated — migrar para SECRETARY
  USER         // Usuário comum
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

enum PaymentMethod {
  PIX
  CREDIT_CARD
  DEBIT_CARD
  BOLETO
  CASH
  TRANSFER
}

enum ContributionStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
  CANCELLED
  REFUNDED
}

// ─── Usuários / Auth ───────────────────────────────────────────────────────────

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String     @unique
  password      String
  role          Role       @default(USER)
  status        UserStatus @default(ACTIVE)
  image         String?
  phone         String?
  cpf           String?    @unique
  emailVerified DateTime?

  passwordResetToken   String?
  passwordResetExpires DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  posts     Post[]
  events    Event[]
  dizimista Dizimista?
  auditLogs AuditLog[]

  @@index([email])
  @@index([role])
  @@index([status])
}

// ─── Conteúdo ──────────────────────────────────────────────────────────────────

model Post {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  content     String    @db.Text
  excerpt     String?
  coverImage  String?
  published   Boolean   @default(false)
  category    String?
  tags        String[]
  views       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  publishedAt DateTime?

  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([slug])
  @@index([published])
}

model Event {
  id          String    @id @default(cuid())
  title       String
  description String    @db.Text
  date        DateTime
  endDate     DateTime?
  location    String?
  image       String?
  siteUrl     String?
  published   Boolean   @default(false)
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([date])
  @@index([published])
  @@index([order])
}

model Community {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  description  String?  @db.Text
  address      String?
  neighborhood String?
  city         String?  @default("Cuiabá")
  state        String?  @default("MT")
  zipCode      String?
  phone        String?
  email        String?
  image        String?
  mapUrl       String?
  active       Boolean  @default(true)
  order        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  masses Mass[]

  @@index([slug])
  @@index([active])
  @@map("communities")
}

model Mass {
  id           String  @id @default(cuid())
  dayOfWeek    String
  time         String
  type         String
  observations String? @db.Text
  active       Boolean @default(true)

  communityId String
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dayOfWeek])
  @@index([communityId])
  @@index([active])
  @@index([dayOfWeek, active])
  @@map("Mass")
}

model Sacrament {
  id        String    @id @default(cuid())
  type      String
  name      String
  email     String?
  phone     String?
  date      DateTime?
  status    String    @default("PENDENTE")
  notes     String?   @db.Text
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([type])
  @@index([status])
  @@index([date])
}

model Donation {
  id        String   @id @default(cuid())
  donorName String?
  email     String?
  amount    Decimal  @db.Decimal(10, 2)
  type      String
  method    String
  notes     String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([type])
}

model Gallery {
  id          String   @id @default(cuid())
  title       String
  description String?
  images      String[]
  eventId     String?
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([published])
}

model Newsletter {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([active])
}

model BannerSlide {
  id        String   @id @default(cuid())
  image     String   @db.Text
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active])
  @@index([order])
  @@map("banner_slides")
}

model HomeHero {
  id       String @id @default(cuid())
  heading  String
  subtitle String
  btn1Text String
  btn1Link String
  btn2Text String
  btn2Link String

  updatedAt DateTime @updatedAt

  @@map("home_hero")
}

model SocialProject {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String   @db.Text
  objective   String?  @db.Text
  schedules   String[]
  location    String?
  audience    String?
  responsible String?
  phone       String?
  whatsapp    String?
  email       String?
  image       String?  @db.Text
  gallery     String[]
  mapUrl      String?
  published   Boolean  @default(false)
  active      Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@index([published])
  @@index([active])
  @@map("social_projects")
}

model SacramentInfo {
  id                String   @id @default(cuid())
  name              String
  description       String   @db.Text
  schedules         String[]
  responsible       String?
  requiredDocuments String[]
  image             String?  @db.Text
  highlight         Boolean  @default(false)
  active            Boolean  @default(true)
  order             Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([active])
  @@index([order])
  @@map("sacrament_info")
}

model Movement {
  id          String   @id @default(cuid())
  name        String
  description String   @db.Text
  coordinator String?
  schedules   String[]
  contact     String?
  image       String?  @db.Text
  highlight   Boolean  @default(false)
  active      Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([active])
  @@index([order])
  @@map("movements")
}

model Clero {
  id             String    @id @default(cuid())
  name           String
  role           String
  photo          String?   @db.Text
  birthDate      DateTime?
  birthCity      String?
  ordinationDate DateTime?
  ordainer       String?
  currentRole    String?
  biography      String?   @db.Text
  instagram      String?
  facebook       String?
  youtube        String?
  whatsapp       String?
  tiktok         String?
  order          Int       @default(0)
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([active])
  @@index([order])
  @@map("clero")
}

// ─── Dizimistas ────────────────────────────────────────────────────────────────

model Dizimista {
  id           String    @id @default(cuid())
  userId       String    @unique
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  cpf          String?   @unique
  birthDate    DateTime?
  address      String?
  neighborhood String?
  city         String?   @default("Cuiabá")
  state        String?   @default("MT")
  zipCode      String?

  registrationDate DateTime @default(now())
  active           Boolean  @default(true)
  notes            String?  @db.Text

  contributions  TitheContribution[]
  recurringPlans RecurringContribution[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([active])
  @@map("dizimistas")
}

model TitheContribution {
  id          String             @id @default(cuid())
  dizimistaId String
  dizimista   Dizimista          @relation(fields: [dizimistaId], references: [id])

  amount     Decimal            @db.Decimal(10, 2)
  competence DateTime           // Primeiro dia do mês de referência
  method     PaymentMethod
  status     ContributionStatus @default(PENDING)

  gatewayId       String?
  gatewayProvider String?
  pixQrCode       String?  @db.Text
  pixCopyPaste    String?  @db.Text
  pixExpiration   DateTime?
  boletoUrl       String?
  boletoBarCode   String?

  paidAt DateTime?
  notes  String?  @db.Text

  receipt TitheReceipt?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dizimistaId])
  @@index([competence])
  @@index([status])
  @@map("tithe_contributions")
}

model TitheReceipt {
  id             String            @id @default(cuid())
  contributionId String            @unique
  contribution   TitheContribution @relation(fields: [contributionId], references: [id])

  receiptNumber String   @unique
  issuedAt      DateTime @default(now())
  pdfUrl        String?

  @@map("tithe_receipts")
}

model RecurringContribution {
  id          String    @id @default(cuid())
  dizimistaId String
  dizimista   Dizimista @relation(fields: [dizimistaId], references: [id])

  amount     Decimal       @db.Decimal(10, 2)
  method     PaymentMethod
  dayOfMonth Int           // Dia do mês para cobrança (1–28)
  active     Boolean       @default(true)

  gatewaySubscriptionId String?

  startDate   DateTime
  endDate     DateTime?
  lastCharged DateTime?
  nextCharge  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dizimistaId])
  @@index([active])
  @@map("recurring_contributions")
}

// ─── Auditoria ─────────────────────────────────────────────────────────────────

model AuditLog {
  id      String  @id @default(cuid())
  userId  String?
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  action   String  // CREATE | UPDATE | DELETE | LOGIN | LOGOUT | PAYMENT
  entity   String  // "User" | "TitheContribution" | "Event" etc.
  entityId String?
  oldData  Json?
  newData  Json?

  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}
