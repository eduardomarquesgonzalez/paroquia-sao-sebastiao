# ──────────────────────────────────────────────────────────────────────────────
# Supabase PostgreSQL
# Obtenha as URLs em: https://supabase.com/dashboard/project/<seu-projeto>/settings/database
#
# Caracteres especiais na senha devem ser URL-encoded:
#   @ → %40  | $ → %24  | # → %23  | [ → %5B  | ] → %5D  | espaço → %20
#
# DATABASE_URL  → Conexão de runtime (queries da aplicação)
#                 Use a URL do Connection Pooler (porta 6543) em produção:
#                 postgresql://postgres.[PROJECT]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true
#
# DIRECT_URL    → Conexão direta para prisma db push / migrate deploy (porta 5432)
#                 postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
# ──────────────────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?sslmode=require&connect_timeout=10"
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?sslmode=require"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="gere-com-openssl-rand-base64-32"

# Conta admin padrão (criada via prisma db seed)
ADMIN_EMAIL="admin@paroquiasaosebastiao.com.br"
ADMIN_PASSWORD="Admin@123456"
ADMIN_NAME="Administrador"

# Cloudinary (opcional — upload de imagens)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# E-mail transacional (opcional — recuperação de senha)
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM=""

# Pagamentos Asaas (opcional — sistema de dízimo)
ASAAS_API_KEY=""
ASAAS_BASE_URL="https://sandbox.asaas.com/api/v3"
PAYMENT_PROVIDER="asaas"
